# CyberWatch — Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit your real .env file to GitHub — it is in .gitignore

# ── Email Alerts (Gmail SMTP) ──────────────────────────────
# Enable email notifications
EMAIL_ENABLED=true

# Your Gmail address
SMTP_USER=gopikrishnachinnam8555@gmail.com

# Gmail App Password (NOT your login password)
# Get one at: Google Account → Security → 2-Step Verification → App passwords
SMTP_PASSWORD=eqvxrgyoyhxpduqr

# Who receives the alert emails
ALERT_EMAIL_TO=gopikrishnachinnam123@gmail.com

# Minimum level to email: ALERT or WATCH
EMAIL_MIN_LEVEL=ALERT

# ── Slack Alerts ───────────────────────────────────────────
# Enable Slack notifications
SLACK_ENABLED=false

# Incoming Webhook URL from your Slack app
# Get one at: api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Minimum level to post to Slack: ALERT or WATCH
SLACK_MIN_LEVEL=ALERT

# ── Dashboard Auth ─────────────────────────────────────────
# Override default dashboard passwords
CYBERWATCH_ADMIN_PASSWORD=cyberwatch2024
CYBERWATCH_ANALYST_PASSWORD=watchdog99

# Session timeout in hours
SESSION_TIMEOUT_HOURS=8

# ── ML Model ───────────────────────────────────────────────
# Confidence threshold for ALERT (0.0 to 1.0)
THREAT_THRESHOLD=0.65

# Expected fraction of attacks in data (Isolation Forest)
CONTAMINATION=0.05

# ── Pipeline Settings ──────────────────────────────────────
# Batch size for log analyzer
BATCH_SIZE=50

# Poll interval for live tail mode (seconds)
POLL_INTERVAL=1.0

# Alert cooldown per IP (seconds)
COOLDOWN_SECONDS=60

# ── Paths ──────────────────────────────────────────────────
LOG_FILE=logs/alerts.log
CSV_FILE=logs/alerts.csv
MODEL_PATH=ml/model.pkl
SCALER_PATH=ml/scaler.pkl

# ── IP Blocking (optional) ─────────────────────────────────
# Automatically block attacker IPs via iptables on ALERT
IP_BLOCKING_ENABLED=false

# ── Spark (optional) ───────────────────────────────────────
SPARK_MASTER=local[*]
